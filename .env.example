# Fine-grained or classic PAT: repo read for private repos you can access.
# For org rollout, replace with GitHub App installation token or per-user OAuth (see README).
GITHUB_TOKEN=

# Anthropic API key (server-side only; never commit real values).
ANTHROPIC_API_KEY=

# Optional override (default in code is a widely available Sonnet snapshot).
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Groq API key (server-side only; never commit real values).
GROQ_API_KEY=

# Optional Groq override model (OpenAI-compatible chat completions).
# GROQ_MODEL=llama3-70b-8192

# Which LLM provider to use for AI features.
# - "anthropic" forces Anthropic
# - "groq" forces Groq
# - if unset: auto-detects (Groq if configured, otherwise Anthropic)
# LLM_PROVIDER=anthropic
